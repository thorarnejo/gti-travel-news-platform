# ============================================================
# GTI News Platform - Environment Variables
# ============================================================

# Required: PostgreSQL Database Connection
# Format: postgresql://user:password@host:port/database
# For Vercel Postgres: postgresql://user:password@host.vercel-storage.com:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/gti_news

# Required: Public Site URL
# Used for server-side API calls and metadata
# Local: http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Use mock data instead of database (for testing/development)
# Set to 'true' to bypass database and use mock data
USE_MOCK_DATA=false

# Optional: Node Environment
# development | production | test
NODE_ENV=development
